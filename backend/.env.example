# Copy to .env and fill in. ANTHROPIC_API_KEY is the universal fallback;
# everything else is opt-in and routes that lang to a better model.

ANTHROPIC_API_KEY=

# K2 Think (IFM/MBZUAI) — primary for English chat. Get from k2think.ai
K2_API_KEY=
K2_BASE_URL=https://api.k2think.ai/v1
K2_MODEL=MBZUAI-IFM/K2-Think-v2

# Inception (G42/IFM) — unlocks Nile-Chat-4B (ar, Egyptian dialectal) and
# Sherkala-8B (kk, Kazakh). Get from docs.inceptionlabs.ai (1-3 day approval).
INCEPTION_API_KEY=
INCEPTION_BASE_URL=https://api.inceptionlabs.ai/v1

# Azure Speech — TTS for en-US, kk-KZ-AigulNeural, ar-EG-SalmaNeural.
# Without this the frontend uses Web Speech (poor on KZ/AR).
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# Reserved for future Nile-Chat / Sherkala self-host
HF_TOKEN=
